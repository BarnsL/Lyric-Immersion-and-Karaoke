# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# Build / logs / one-off scratch
*.log
preload.log
build_*.exit
build_*.log
build_*.err
_batch_fetch*
*.done

# Spotify auth — local secrets / tokens, never commit
spotify_config.json
.spotify_cache

# Cached song lyrics are copyrighted third-party content — not redistributed.
# Run `python preload.py` (or just play music) to build your own local library.
# Ignore EVERYTHING under lyrics/ (the cache, any nested private backup repo's
# .git, and the personal library DB) except the .gitkeep placeholder — so none of
# that copyrighted/personal data can ever leak into this public repo.
lyrics/*
!lyrics/.gitkeep

# Baked-in fallback lyrics shipped with the app are copyrighted third-party
# content. Kept LOCALLY (so YOUR own builds can still bundle them via the spec's
# optional include) but never committed — a clean clone, and any public/sold
# build made from it, ships with NONE baked in.
bundled_lyrics/

# Sales / business planning notes are LOCAL-ONLY — never commit to the public repo.
docs/SALES_CONSIDERATIONS.md

# OS
Thumbs.db
desktop.ini
.DS_Store

# Local UI preferences
settings.json

# Icon-generation scratch / previews
_icon_preview.png
_preview_cur.png
_exe_icon.png

# Optional "sync by listening" runtime (faster-whisper) + downloaded ASR models
# — vendored locally, never committed (heavy, machine-specific).
.deps/
.deps-ship/
deps/
models/

# Build artifacts
build/
dist/
*.exe
*.msix
*.msixupload
*.spec.bak
lyrics/*.tmp
lyrics/*.json.tmp

# MSIX packaging outputs (build_msix.ps1 writes these under dist/, but guard
# against running make_assets.py from the repo root)
/Assets/
priconfig.xml

# Local 3h-watch + release packaging artifacts
_monitor.py
_monitor*.jsonl
_zip_release.py
DesktopKaraoke-portable.zip
DesktopKaraoke-portable.zip.sha256
*.bak
